# このファイルを .env.local にコピーして使用します:  cp .env.example .env.local

# Ollama API 接続先
OLLAMA_BASE_URL=http://localhost:11434

# 使用モデル（実際に `ollama pull` したモデル名に合わせること）
# アプリのデフォルトは大型モデル。低スペック機では軽量モデル（例: gemma3:4b）を指定する
OLLAMA_MODEL=qwen3-coder-next:latest

# PostgreSQL 接続文字列（docker-compose.yml と一致させる。ポート 5499）
DATABASE_URL=postgresql://postgres:postgres@localhost:5499/chat_db

# --- エージェント機能（任意。未設定時は下記デフォルトが使われる） ---
# エージェントループの最大ツール呼び出しラウンド数
AGENT_MAX_TOOL_ROUNDS=10
# ツール実行タイムアウト（ミリ秒）
AGENT_TOOL_TIMEOUT_MS=30000
